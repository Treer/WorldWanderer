{
  "DiagnosticsDataPath": ".\\devLogging",

  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "MapGen.Tiles.Continent": "Warning",
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": ".\\devLogging\\logs\\log-.txt",
          "rollingInterval": "Day"
        }
      }
    ]
  }
}